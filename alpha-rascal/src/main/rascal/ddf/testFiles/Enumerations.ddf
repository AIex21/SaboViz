typedef enum {
    RED,
    GREEN,
    BLUE
} Color ;

typedef enum {
    NONE = 0,
    READ = 1 <description = "Read access">,
    WRITE = 2 <description = "Write access">,
    READ_WRITE = READ | WRITE <description = "Full access">
} Permission stringdefines;

typedef enum {
    LOW = 0,
    MEDIUM = LOW + 1,
    HIGH = MEDIUM + 1,
    CRITICAL = HIGH | (1 << 3)
} Priority ;