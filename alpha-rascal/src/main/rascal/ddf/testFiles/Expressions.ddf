const EXPR1 = (1 + 2) * 3 - (4 / 2) ;
const EXPR2 = FLAG & (MASK | (1 << 3)) ;
const EXPR3 = ~(FLAG ^ MASK) & (VALUE >> 2) ;
const EXPR4 = @type_id + (SIZE * 4) ;
const EXPR5 = !(READY & VALID) | (TIMEOUT << 1) ;

cmexpression DEBUG = (mode == "debug") ;
cmexpression RELEASE = (mode == "release" && arch == "x86") ;
cmexpression TEST = ((env == "test") || (env == "staging")) ;
cmexpression COMPLEX = (platform == "linux" && (arch == "x86" || arch == "arm")) ;